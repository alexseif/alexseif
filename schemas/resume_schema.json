{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Static Resume Data Base",
  "type": "object",
  "properties": {
    "name": { "type": "string" },
    "titles": {
      "type": "array",
      "items": { "type": "string" },
      "description": "e.g., ['Software Architect', 'NGO Technical Partner']"
    },
    "contact": {
      "type": "object",
      "properties": {
        "mobile": { "type": "string" },
        "email": { "type": "string" },
        "website": { "type": "string" },
        "case_studies": { "type": "string" }
      }
    },
    "summary": { "type": "string" },
    "education": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "degree": { "type": "string" },
          "institution": { "type": "string" },
          "year": { "type": "integer" }
        }
      }
    },
    "technical_leadership": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "required": ["name", "titles", "contact", "summary"]
}
